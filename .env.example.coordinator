# Coordinator environment configuration
# Copy this file to .env: cp .env.example.coordinator .env
# Fill in values as you progress through CEREMONY-COORDINATOR.md

# Path to your FROST config file (created during frost-init)
FROST_CONFIG_PATH=~/.config/frost/config

# frostd coordination server — bare hostname, no https:// (the FROST client adds it internally)
FROST_SERVER_URL=

# Notification service — full URL with https://
NOTIFICATION_SERVICE_URL=
NOTIFICATION_NAMESPACE=nori-multisig

# Mina network
MINA_RPC_NETWORK_URL=https://api.minascan.io/node/devnet/v1/graphql
MINA_NETWORK=testnet
MINA_SENDER_PRIVATE_KEY=
MINA_TX_FEE=0.1

# Contract addresses (from DKG — filled in after DKG completes)
NORI_MINA_TOKEN_BRIDGE_ADDRESS=       # Admin contract address
NORI_MINA_TOKEN_BASE_ADDRESS=         # Token contract address

# Docker image override (optional)
# FROST_CLIENT_IMAGE=0x6a6f6e6e79/frost-mina-client:latest
